{
  "conda": {
    "description": "A package and environment manager for Python and other languages.",
    "tags": [
      "python",
      "environment",
      "package-manager",
      "ml",
      "cli"
    ],
    "topics": {
      "create-environment": {
        "description": "Create a new isolated environment",
        "what_it_does": "Creates a new environment with a specific Python version and optional packages.",
        "syntax": [
          "conda create -n <env_name> python=<version>",
          "conda create -n <env_name> <packages>"
        ],
        "examples": [
          "conda create -n myenv python=3.11",
          "conda create -n dataenv numpy pandas"
        ],
        "tags": [
          "env",
          "setup"
        ]
      },
      "activate-environment": {
        "description": "Activate an environment",
        "what_it_does": "Switches the current shell to use the specified environment.",
        "syntax": [
          "conda activate <env_name>"
        ],
        "examples": [
          "conda activate myenv"
        ],
        "tags": [
          "env",
          "switch"
        ]
      },
      "deactivate-environment": {
        "description": "Deactivate the current environment",
        "what_it_does": "Returns to the base environment or previous shell state.",
        "syntax": [
          "conda deactivate"
        ],
        "examples": [
          "conda deactivate"
        ],
        "tags": [
          "env"
        ]
      },
      "install-packages": {
        "description": "Install packages into an environment",
        "what_it_does": "Installs packages from conda repositories into the active environment.",
        "syntax": [
          "conda install <package>",
          "conda install -n <env_name> <package>"
        ],
        "examples": [
          "conda install numpy",
          "conda install -n myenv scipy"
        ],
        "tags": [
          "packages"
        ]
      },
      "list-environments": {
        "description": "List all environments",
        "what_it_does": "Displays all available conda environments on the system.",
        "syntax": [
          "conda env list",
          "conda info --envs"
        ],
        "examples": [
          "conda env list",
          "conda info --envs"
        ],
        "tags": [
          "env"
        ]
      },
      "remove-environment": {
        "description": "Delete an environment",
        "what_it_does": "Removes an environment and all its installed packages.",
        "syntax": [
          "conda remove -n <env_name> --all"
        ],
        "examples": [
          "conda remove -n myenv --all"
        ],
        "tags": [
          "env",
          "cleanup"
        ]
      },
      "update-packages": {
        "description": "Update conda or installed packages",
        "what_it_does": "Updates conda itself or specific packages to the latest compatible versions.",
        "syntax": [
          "conda update conda",
          "conda update <package>"
        ],
        "examples": [
          "conda update conda",
          "conda update numpy"
        ],
        "tags": [
          "packages",
          "update"
        ]
      },
      "export-environment": {
        "description": "Export environment configuration",
        "what_it_does": "Exports the environment dependencies into a YAML file for sharing or reproduction.",
        "syntax": [
          "conda env export > <file.yml>"
        ],
        "examples": [
          "conda env export > environment.yml"
        ],
        "tags": [
          "env",
          "share"
        ]
      },
      "create-from-file": {
        "description": "Create environment from YAML file",
        "what_it_does": "Creates a new environment using a previously exported configuration file.",
        "syntax": [
          "conda env create -f <file.yml>"
        ],
        "examples": [
          "conda env create -f environment.yml"
        ],
        "tags": [
          "env",
          "setup"
        ]
      },
      "config conda base": {
        "description": "changes the conda base configuration from the terminal",
        "what_it_does": "change conda base config at terminal start",
        "syntax": [
          "conda config --set auto_activate_base false"
        ],
        "examples": [
          "conda config --set auto_activate_base false"
        ],
        "tags": [
          "conda",
          "config",
          "base"
        ]
      }
    }
  },
  "git": {
    "description": "Distributed version control system for tracking code changes",
    "tags": [
      "version-control",
      "cli",
      "development",
      "git"
    ],
    "topics": {
      "init": {
        "description": "Initialize a repository",
        "what_it_does": "Creates a new Git repository in the current directory",
        "syntax": [
          "git init",
          "git init <directory>"
        ],
        "examples": [
          "git init",
          "git init my-project"
        ],
        "tags": [
          "setup",
          "repo"
        ]
      },
      "clone": {
        "description": "Clone a repository",
        "what_it_does": "Downloads an existing repository from a remote source",
        "syntax": [
          "git clone <url>",
          "git clone <url> <directory>"
        ],
        "examples": [
          "git clone https://github.com/user/repo.git",
          "git clone https://github.com/user/repo.git my-folder"
        ],
        "tags": [
          "remote",
          "download"
        ]
      },
      "commit": {
        "description": "Save changes",
        "what_it_does": "Records staged changes into the repository history",
        "syntax": [
          "git commit -m \"message\"",
          "git commit"
        ],
        "examples": [
          "git commit -m \"initial commit\"",
          "git commit -m \"fix bug\""
        ],
        "tags": [
          "save",
          "history"
        ]
      },
      "branch": {
        "description": "Manage branches",
        "what_it_does": "Creates, lists, or deletes branches",
        "syntax": [
          "git branch",
          "git branch <name>",
          "git branch -d <name>"
        ],
        "examples": [
          "git branch",
          "git branch feature-login",
          "git branch -d old-feature"
        ],
        "tags": [
          "branching"
        ]
      },
      "merge": {
        "description": "Merge branches",
        "what_it_does": "Combines changes from one branch into another",
        "syntax": [
          "git merge <branch>"
        ],
        "examples": [
          "git merge feature-login"
        ],
        "tags": [
          "integration"
        ]
      },
      "status": {
        "description": "Check repository status",
        "what_it_does": "Shows modified, staged, and untracked files",
        "syntax": [
          "git status"
        ],
        "examples": [
          "git status"
        ],
        "tags": [
          "info"
        ]
      }
    }
  },
  "curl": {
    "description": "Command-line tool for transferring data with URLs supporting HTTP, HTTPS, FTP, and more",
    "tags": [
      "http",
      "network",
      "api",
      "download",
      "transfer"
    ],
    "topics": {
      "basic-request": {
        "description": "Simple HTTP GET request",
        "what_it_does": "Fetches the content of a URL and prints it to stdout",
        "syntax": [
          "curl <url>",
          "curl -o <file> <url>"
        ],
        "examples": [
          "curl https://example.com",
          "curl -o page.html https://example.com"
        ],
        "tags": [
          "get",
          "fetch",
          "basic"
        ]
      },
      "headers": {
        "description": "Sending and viewing HTTP headers",
        "what_it_does": "Add custom request headers or inspect response headers",
        "syntax": [
          "curl -H \"<Header>: <value>\" <url>",
          "curl -I <url>",
          "curl -v <url>"
        ],
        "examples": [
          "curl -H \"Authorization: Bearer mytoken\" https://api.example.com",
          "curl -H \"Content-Type: application/json\" https://api.example.com",
          "curl -I https://example.com",
          "curl -v https://example.com"
        ],
        "tags": [
          "headers",
          "auth",
          "inspect"
        ]
      },
      "post-request": {
        "description": "Send data via HTTP POST",
        "what_it_does": "Submit form data or JSON body to an endpoint",
        "syntax": [
          "curl -X POST -d \"<data>\" <url>",
          "curl -X POST -H \"Content-Type: application/json\" -d \"<json>\" <url>"
        ],
        "examples": [
          "curl -X POST -d \"name=john&age=30\" https://api.example.com/users",
          "curl -X POST -H \"Content-Type: application/json\" -d \"{\\\"name\\\":\\\"john\\\"}\" https://api.example.com/users"
        ],
        "tags": [
          "post",
          "send",
          "api",
          "json"
        ]
      },
      "download": {
        "description": "Download files from a URL",
        "what_it_does": "Save remote files to disk, with progress or silent mode",
        "syntax": [
          "curl -O <url>",
          "curl -o <filename> <url>",
          "curl -L -O <url>"
        ],
        "examples": [
          "curl -O https://example.com/file.zip",
          "curl -o myfile.zip https://example.com/file.zip",
          "curl -L -O https://example.com/redirect-download"
        ],
        "tags": [
          "download",
          "file",
          "save"
        ]
      },
      "auth": {
        "description": "Authentication methods",
        "what_it_does": "Pass credentials via basic auth, bearer token, or API key",
        "syntax": [
          "curl -u <user>:<password> <url>",
          "curl -H \"Authorization: Bearer <token>\" <url>",
          "curl -H \"x-api-key: <key>\" <url>"
        ],
        "examples": [
          "curl -u admin:secret https://api.example.com/protected",
          "curl -H \"Authorization: Bearer eyJhbGci...\" https://api.example.com/me",
          "curl -H \"x-api-key: abc123\" https://api.example.com/data"
        ],
        "tags": [
          "auth",
          "security",
          "token",
          "api-key"
        ]
      },
      "follow-redirects": {
        "description": "Follow HTTP redirects automatically",
        "what_it_does": "Tells curl to follow 3xx redirect responses to the final destination",
        "syntax": [
          "curl -L <url>"
        ],
        "examples": [
          "curl -L https://bit.ly/someshortlink",
          "curl -L -O https://github.com/user/repo/archive/main.zip"
        ],
        "tags": [
          "redirect",
          "follow",
          "location"
        ]
      },
      "upload": {
        "description": "Upload a file to a server",
        "what_it_does": "Send a local file as part of a POST or PUT request",
        "syntax": [
          "curl -F \"<field>=@<filepath>\" <url>",
          "curl -X PUT --data-binary @<file> <url>"
        ],
        "examples": [
          "curl -F \"file=@report.pdf\" https://api.example.com/upload",
          "curl -X PUT --data-binary @image.png https://api.example.com/avatar"
        ],
        "tags": [
          "upload",
          "file",
          "post",
          "put"
        ]
      },
      "proxy": {
        "description": "Route requests through a proxy",
        "what_it_does": "Send curl traffic through an HTTP or SOCKS proxy",
        "syntax": [
          "curl -x <proxy_url> <url>",
          "curl --socks5 <host>:<port> <url>"
        ],
        "examples": [
          "curl -x http://proxy.example.com:8080 https://target.com",
          "curl --socks5 127.0.0.1:1080 https://target.com"
        ],
        "tags": [
          "proxy",
          "socks",
          "network"
        ]
      }
    }
  },
  "terminal": {
    "description": "Command-line interface for interacting with the OS via text commands on Windows, Linux, or Mac",
    "tags": [
      "shell",
      "cli",
      "powershell",
      "bash",
      "cmd",
      "windows",
      "linux"
    ],
    "topics": {
      "navigation": {
        "description": "Moving between directories and listing contents",
        "what_it_does": "Lets you traverse the filesystem, see what's in folders, and know where you are",
        "syntax": [
          "cd <path>",
          "cd ..",
          "ls / dir",
          "pwd / cd (no args on Windows)"
        ],
        "examples": [
          "cd D:\\Vault\\Projects",
          "cd ../Research",
          "ls -la",
          "dir /b"
        ],
        "tags": [
          "filesystem",
          "navigation",
          "directory"
        ]
      },
      "file-operations": {
        "description": "Creating, copying, moving, and deleting files and folders",
        "what_it_does": "Manage files directly from the terminal without a file explorer",
        "syntax": [
          "cp <src> <dest>  /  copy <src> <dest>",
          "mv <src> <dest>  /  move <src> <dest>",
          "rm <file>        /  del <file>",
          "mkdir <dir>",
          "touch <file>     /  ni <file>"
        ],
        "examples": [
          "cp output.wav D:\\Vault\\Audio\\",
          "mv old_name.py new_name.py",
          "rm -rf build/",
          "mkdir -p src/models",
          "ni config.json"
        ],
        "tags": [
          "files",
          "copy",
          "delete",
          "move",
          "create"
        ]
      },
      "environment-variables": {
        "description": "Reading and setting environment variables in the shell",
        "what_it_does": "Access system-level variables like PATH, or set temp vars for the current session",
        "syntax": [
          "echo $VAR_NAME           (bash)",
          "echo $env:VAR_NAME      (powershell)",
          "export VAR=value        (bash)",
          "$env:VAR = 'value'      (powershell)",
          "set VAR=value           (cmd)"
        ],
        "examples": [
          "echo $env:PATH",
          "$env:HF_TOKEN = 'abc123'",
          "export CUDA_VISIBLE_DEVICES=0",
          "echo %APPDATA%"
        ],
        "tags": [
          "env",
          "variables",
          "path",
          "config"
        ]
      },
      "process-management": {
        "description": "Running, backgrounding, and killing processes",
        "what_it_does": "Control running programs — check what's running, kill hung processes, or run tasks in background",
        "syntax": [
          "ps / Get-Process",
          "kill <pid> / Stop-Process -Id <pid>",
          "command &          (bash background)",
          "Start-Job { }      (powershell background)",
          "taskkill /PID <pid> /F"
        ],
        "examples": [
          "Get-Process python",
          "Stop-Process -Name python -Force",
          "python train.py &",
          "taskkill /IM python.exe /F"
        ],
        "tags": [
          "process",
          "kill",
          "background",
          "jobs"
        ]
      },
      "piping-and-redirection": {
        "description": "Chaining commands and redirecting output to files",
        "what_it_does": "Pass output of one command as input to another, or save output to a file instead of printing it",
        "syntax": [
          "command | command",
          "command > file.txt",
          "command >> file.txt",
          "command 2>&1"
        ],
        "examples": [
          "pip list | grep torch",
          "python inference.py > output.log",
          "python train.py >> train.log 2>&1",
          "Get-Process | Where-Object { $_.CPU -gt 100 }"
        ],
        "tags": [
          "pipe",
          "redirect",
          "output",
          "log"
        ]
      },
      "searching": {
        "description": "Finding files or text content in the terminal",
        "what_it_does": "Search recursively through files and directories by name or content",
        "syntax": [
          "find <path> -name <pattern>",
          "grep -r <pattern> <path>",
          "Get-ChildItem -Recurse -Filter <pattern>",
          "Select-String -Path <file> -Pattern <text>"
        ],
        "examples": [
          "find . -name '*.py'",
          "grep -r 'SopranoTTS' ./soprano",
          "Get-ChildItem -Recurse -Filter *.wav",
          "Select-String -Path *.log -Pattern 'ERROR'"
        ],
        "tags": [
          "search",
          "find",
          "grep",
          "filter"
        ]
      },
      "package-management": {
        "description": "Installing and managing Python packages from the terminal",
        "what_it_does": "Use pip or conda to install, upgrade, list, or remove packages in your environment",
        "syntax": [
          "pip install <package>",
          "pip install -r requirements.txt",
          "pip uninstall <package>",
          "conda install <package>",
          "conda activate <env>"
        ],
        "examples": [
          "pip install soprano-tts",
          "pip install -r requirements.txt",
          "pip install torch==2.8.0 --index-url https://download.pytorch.org/whl/cu128",
          "conda create -n voxsara python=3.10",
          "conda activate voxsara"
        ],
        "tags": [
          "pip",
          "conda",
          "install",
          "packages",
          "python"
        ]
      },
      "aliases-and-profile": {
        "description": "Creating shortcuts for commands and persisting them across sessions",
        "what_it_does": "Set aliases so short commands run longer ones, and save them to your shell profile so they persist",
        "syntax": [
          "Set-Alias <name> <command>      (powershell)",
          "function <name> { <command> }   (powershell)",
          "alias <name>='<command>'        (bash)",
          "notepad $PROFILE               (edit powershell profile)"
        ],
        "examples": [
          "Set-Alias gs git status",
          "function activate { conda activate voxsara }",
          "alias ll='ls -la'",
          "Remove-Item Alias:curl"
        ],
        "tags": [
          "alias",
          "profile",
          "shortcut",
          "powershell",
          "bash"
        ]
      }
    }
  }
}